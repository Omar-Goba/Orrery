# LLM roles
# Each role accepts any OpenAI-compatible endpoint: OpenAI, Ollama /v1, or a compatible gateway.
# The values below are starter examples; configure every role needed by your workflow.
# The default configuration uses external OpenAI-compatible services. For local Ollama,
# see the profile settings below; Compose service DNS does not resolve localhost to Ollama.
LLM_SUMMARY__BASE_URL=https://api.openai.com/v1
LLM_SUMMARY__API_KEY=sk-...
LLM_SUMMARY__MODEL=gpt-4o-mini

LLM_NAMER__BASE_URL=https://api.openai.com/v1
LLM_NAMER__API_KEY=sk-...
LLM_NAMER__MODEL=gpt-4o-mini

LLM_EMBEDDER__BASE_URL=https://api.openai.com/v1
LLM_EMBEDDER__API_KEY=sk-...
LLM_EMBEDDER__MODEL=text-embedding-3-small

LLM_ORACLE__BASE_URL=https://api.openai.com/v1
LLM_ORACLE__API_KEY=sk-...
LLM_ORACLE__MODEL=gpt-4o-mini

LLM_CURATOR__BASE_URL=https://api.openai.com/v1
LLM_CURATOR__API_KEY=sk-...
LLM_CURATOR__MODEL=gpt-4o-mini

LLM_MASTER__BASE_URL=https://api.openai.com/v1
LLM_MASTER__API_KEY=sk-...
LLM_MASTER__MODEL=gpt-4o-mini

# Mistral OCR
MISTRAL_API_KEY=...

# Docker Compose profiles
# Leave empty for the default stack, which uses the external LLM endpoints above.
# Set to local-llm to start bundled Ollama and pull OLLAMA_EMBED_MODEL. Then set the
# embedder BASE_URL to http://ollama:11434/v1, leave its API key blank, and set its
# model to the exact OLLAMA_EMBED_MODEL value. Provision any other local role models
# separately. The profile and role URLs remain separate controls.
COMPOSE_PROFILES=
OLLAMA_EMBED_MODEL=mxbai-embed-large

# Paths
# These paths support non-Docker local development. Compose explicitly overrides them
# with /data, /data/chroma, and /data/logs on the orrery_data named volume.
ORRERY_DBS_DIR=./dbs
ORRERY_CHROMA_PERSIST_DIR=./dbs/chroma
ORRERY_LOG_DIR=./dbs/logs

# Server
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Auth (Tier 2, phase 1)
# signup mode: open | invite | closed
ORRERY_SIGNUP_MODE=invite
ORRERY_INVITE_CODE=changeme-invite-code
ORRERY_DEFAULT_QUOTA=524288000
ORRERY_IS_PRODUCTION=false

# Object storage
# Local non-Docker development uses the filesystem by default. To use any S3-compatible
# provider outside Compose, set this to s3 and configure the generic S3 values below.
ORRERY_OBJECT_STORE=local
ORRERY_S3_BUCKET=orrery
# Compose overrides this with http://minio:9000, which is container DNS and is not a
# host URL. Only the MinIO console is published to the host, at http://localhost:9001.
ORRERY_S3_ENDPOINT_URL=
ORRERY_S3_REGION=us-east-1
# Provider credentials for generic S3 mode outside Compose. Compose supplies these
# settings to the backend from the MinIO credentials below instead.
ORRERY_S3_ACCESS_KEY_ID=replace-with-s3-access-key
ORRERY_S3_SECRET_ACCESS_KEY=replace-with-s3-secret-key
# auto | path | virtual; Compose overrides this to path for MinIO.
ORRERY_S3_ADDRESSING_STYLE=auto
# Changing the bucket after objects exist selects a different logical object store; it
# does not move or rename objects already stored in the old bucket.
# Nginx allows 110 MiB for multipart overhead. If ORRERY_MAX_PDF_BYTES is raised
# above 100 MiB, also raise client_max_body_size in frontend/nginx.conf.
ORRERY_MAX_PDF_BYTES=104857600

# MinIO administrator credentials for Docker Compose. The local stack also uses this
# pair for backend S3 access. Passwords must be at least 8 characters.
MINIO_ROOT_USER=replace-with-local-access-key
MINIO_ROOT_PASSWORD=replace-with-local-secret-key

# Public tour (Tier 2, phase 5)
ORRERY_TOUR_CHAT=true

# Keeper storage lens (Tier 2, phase 6)
ORRERY_KEEPER_CAN_OPEN_FILES=false

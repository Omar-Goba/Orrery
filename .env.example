# LLM roles
# Each role accepts any OpenAI-compatible endpoint: OpenAI, Ollama /v1, or a compatible gateway.
# For local Ollama, use BASE_URL=http://localhost:11434/v1 and leave API_KEY blank.
# Inside Docker Compose with the local-llm profile, use BASE_URL=http://ollama:11434/v1.
# Compose service DNS does not resolve localhost to the Ollama container.
LLM_SUMMARY__BASE_URL=https://api.openai.com/v1
LLM_SUMMARY__API_KEY=sk-...
LLM_SUMMARY__MODEL=gpt-4o-mini

LLM_NAMER__BASE_URL=https://api.openai.com/v1
LLM_NAMER__API_KEY=sk-...
LLM_NAMER__MODEL=gpt-4o-mini

LLM_EMBEDDER__BASE_URL=http://localhost:11434/v1
LLM_EMBEDDER__API_KEY=
LLM_EMBEDDER__MODEL=mxbai-embed-large

LLM_ORACLE__BASE_URL=https://api.openai.com/v1
LLM_ORACLE__API_KEY=sk-...
LLM_ORACLE__MODEL=gpt-4o-mini

LLM_CURATOR__BASE_URL=https://api.openai.com/v1
LLM_CURATOR__API_KEY=sk-...
LLM_CURATOR__MODEL=gpt-4o-mini

LLM_MASTER__BASE_URL=https://api.openai.com/v1
LLM_MASTER__API_KEY=sk-...
LLM_MASTER__MODEL=gpt-4o-mini

# Mistral OCR
MISTRAL_API_KEY=...

# Paths
# Container defaults are /data, /data/chroma, and /data/logs.
# For non-Docker local development, keep these overrides in your gitignored .env:
ORRERY_DBS_DIR=./dbs
ORRERY_CHROMA_PERSIST_DIR=./dbs/chroma
ORRERY_LOG_DIR=./dbs/logs

# Server
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Auth (Tier 2, phase 1)
# signup mode: open | invite | closed
ORRERY_SIGNUP_MODE=invite
ORRERY_INVITE_CODE=changeme-invite-code
ORRERY_DEFAULT_QUOTA=524288000
ORRERY_IS_PRODUCTION=false

# Object storage (Tier 2, phase 2) — per-file cap; full quota accounting is phase 6
ORRERY_MAX_PDF_BYTES=104857600

# Public tour (Tier 2, phase 5)
ORRERY_TOUR_CHAT=true

# Keeper storage lens (Tier 2, phase 6)
ORRERY_KEEPER_CAN_OPEN_FILES=false

# OpenAI
OPENAI_API_KEY=sk-...
SUMMARY_MODEL=gpt-4o-mini
NAMER_MODEL=gpt-4o-mini

# Mistral OCR
MISTRAL_API_KEY=...

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=mxbai-embed-large
OLLAMA_NAMER_MODEL=gemma3:4b

# Paths (relative to project root)
DBS_DIR=./dbs
CHROMA_PERSIST_DIR=./dbs/chroma

# Server
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Auth (Tier 2, phase 1)
# signup mode: open | invite | closed
ORRERY_SIGNUP_MODE=invite
ORRERY_INVITE_CODE=changeme-invite-code
ORRERY_DEFAULT_QUOTA=524288000
ORRERY_IS_PRODUCTION=false

# Object storage (Tier 2, phase 2) — per-file cap; full quota accounting is phase 6
ORRERY_MAX_PDF_BYTES=104857600
